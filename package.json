{
  "name": "sitepack-cli",
  "version": "1.1.2",
  "type": "module",
  "bin": {
    "sitepack": "./bin/sitepack.js"
  },
  "scripts": {
    "preinstall": "node -e \"if(process.env.npm_execpath && !process.env.npm_execpath.includes('yarn') && !process.env.npm_execpath.includes('npm')) { console.error('Please use npm or yarn to install dependencies'); process.exit(1); }\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "axios": "1.15.2",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "commander": "^12.0.0",
    "form-data": "^4.0.5",
    "fs-extra": "^11.2.0",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "inquirer": "^9.2.15",
    "open": "^11.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  },
  "packageManager": "yarn@1.22.22"
}
